{
  "metadata": {
    "environment": "yuno-production-snapshot",
    "evidence_source": "local_fixture: compliant.json",
    "collected_by": "compliance_evidence v0.1 (simulated API aggregation)"
  },
  "iam": {
    "root_mfa_enabled": true,
    "users": [
      { "name": "alice", "mfa_enabled": true },
      { "name": "breakglass", "mfa_enabled": true }
    ],
    "policies": [
      {
        "policy_name": "AppRuntimeS3Read",
        "attached_to": ["role/payment-api"],
        "statement": [
          {
            "Effect": "Allow",
            "Action": ["s3:GetObject", "s3:ListBucket"],
            "Resource": [
              "arn:aws:s3:::yuno-prod-customer-data",
              "arn:aws:s3:::yuno-prod-customer-data/*"
            ]
          }
        ]
      },
      {
        "policy_name": "RDSConnectLimited",
        "attached_to": ["role/payment-api"],
        "statement": [
          {
            "Effect": "Allow",
            "Action": ["rds:DescribeDBInstances", "rds-db:connect"],
            "Resource": "arn:aws:rds:us-east-1:123456789012:db:orders"
          }
        ]
      }
    ]
  },
  "s3": {
    "buckets": [
      {
        "name": "yuno-prod-customer-data",
        "region": "us-east-1",
        "encryption": { "enabled": true, "algorithm": "aws:kms", "kms_key_id": "arn:aws:kms:us-east-1:123456789012:key/abc" },
        "public_access_blocked": true
      },
      {
        "name": "yuno-prod-cloudtrail-logs",
        "region": "us-east-1",
        "encryption": { "enabled": true, "algorithm": "aws:kms", "kms_key_id": "arn:aws:kms:us-east-1:123456789012:key/def" },
        "public_access_blocked": true
      }
    ]
  },
  "rds": {
    "instances": [
      {
        "identifier": "orders-primary",
        "engine": "postgres",
        "storage_encrypted": true,
        "kms_key_id": "arn:aws:kms:us-east-1:123456789012:key/abc"
      }
    ]
  },
  "cloudtrail": {
    "regions_required": ["us-east-1", "eu-west-1"],
    "multi_region_trail": true,
    "log_archive_bucket_configured": true,
    "regions": {
      "us-east-1": { "enabled": true, "is_logging": true },
      "eu-west-1": { "enabled": true, "is_logging": true }
    }
  }
